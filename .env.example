# Admin login (used to access /admin)
ADMIN_PASSWORD=admin
SESSION_SECRET=change-me-to-a-long-random-string

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# App
# For local dev with Telegram, expose via ngrok/cloudflared and set the public URL here.
# Telegram needs an absolute, publicly-reachable URL to fetch invoice PDFs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: override paths (defaults are ./data.db and ./storage)
# DB_PATH=
# STORAGE_PATH=
